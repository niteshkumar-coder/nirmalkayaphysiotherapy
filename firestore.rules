rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidAppointment(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 250 &&
             data.phone is string && data.phone.size() >= 4 && data.phone.size() <= 50 &&
             data.date is string &&
             data.time is string &&
             (!('treatment' in data) || data.treatment is string) &&
             (!('condition' in data) || data.condition is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /appointments/{appointmentId} {
      allow create: if request.resource.data.name is string && 
                    request.resource.data.phone is string && 
                    request.resource.data.date is string && 
                    request.resource.data.time is string;
      // For now, allow reading all appointments so the admin dashboard works with the password
      // In a production app, this should be restricted to authenticated admin users
      allow read: if true; 
    }
  }
}
